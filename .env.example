# Server runtime
NODE_ENV=development
PORT=5000

# MongoDB
# Local example: mongodb://127.0.0.1:27017
# Atlas example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=travel_ai_planner

AI_INTEGRATIONS_OPENAI_API_KEY=your_api_key_here
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.groq.com/openai/v1
